# CWA LiteLLM API 金鑰（必填）
CWA_LITELLM_KEY=sk-xxxx

# 若設定 ANTHROPIC_AUTH_TOKEN，將優先使用此值，CWA_LITELLM_KEY 會被忽略
# ANTHROPIC_AUTH_TOKEN=sk-xxxx

# 覆寫 LiteLLM 端點 URL（預設：https://litellm.cwa.gov.tw）
# ANTHROPIC_BASE_URL=https://litellm.cwa.gov.tw

# 選填：覆寫模型對應（預設使用 Anthropic 內建模型）
# ANTHROPIC_DEFAULT_OPUS_MODEL=your-model
# ANTHROPIC_DEFAULT_SONNET_MODEL=your-model
# ANTHROPIC_DEFAULT_HAIKU_MODEL=your-model
